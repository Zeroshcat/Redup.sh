# Server
PORT=8080
GIN_MODE=debug

# Database
DATABASE_URL=postgres://redup:redup@localhost:5432/redup?sslmode=disable

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT secrets — generate strong random values in production
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# CORS
CORS_ALLOW_ORIGIN=http://localhost:3000

# Anonymous ID prefix — format is "{prefix}-{snowflake}" (e.g. redup-l8s4j9k3m2)
# Admin panel will override this at runtime.
ANON_ID_PREFIX=Anon

# Snowflake node id — must be 0-1023 and unique per backend instance.
# Change this if you run multiple backends to avoid id collisions.
SNOWFLAKE_NODE_ID=1

# ---------- Bot dispatcher ----------
# Master switch for the bot trigger system. When false, @botslug mentions and
# manual summon calls are ignored regardless of bot status. Set to true after
# you've onboarded at least one bot owner.
BOT_ENABLED=false

# Per-call timeout (seconds) for both webhook delivery to user bots AND for
# platform LLM calls (translation/moderation/summarization).
BOT_TIMEOUT_SEC=15

# How many recent posts of a topic to forward as context to a triggered bot.
BOT_MAX_CONTEXT=20

# ---------- Platform LLM ----------
# LLM provider credentials (OpenAI, Anthropic, DeepSeek, Moonshot, local
# Ollama, any OpenAI-compatible endpoint) are managed exclusively from
# the admin panel: /admin/site → LLM 提供方. There are intentionally no
# env vars here — one source of truth, editable without a redeploy.
