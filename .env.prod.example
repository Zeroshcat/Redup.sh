# Copy to .env.prod and fill in real values. NEVER commit .env.prod.
#
#   cp .env.prod.example .env.prod
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ---------- database ----------
POSTGRES_USER=redup
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=redup

# ---------- jwt secrets ----------
# Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-generate-32-bytes
JWT_REFRESH_SECRET=change-me-generate-32-bytes
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ---------- public URLs ----------
# The frontend calls the backend via this URL from the browser. In a
# single-host split-port setup it's http://your.domain:8080; behind a
# reverse proxy use https://your.domain/api.
NEXT_PUBLIC_API_URL=https://your.domain.com
# Origin allowed by backend CORS. Must exactly match the frontend origin.
CORS_ALLOW_ORIGIN=https://your.domain.com

# ---------- anon / snowflake ----------
ANON_ID_PREFIX=Anon
SNOWFLAKE_NODE_ID=1

# ---------- bot subsystem ----------
BOT_ENABLED=true
BOT_TIMEOUT_SEC=15
BOT_MAX_CONTEXT=20

# ---------- platform llm (optional) ----------
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ---------- observability (optional) ----------
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# ---------- host port mapping ----------
BACKEND_PORT=8080
FRONTEND_PORT=3000
